```html
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>DeepSeek 悬浮客服测试</title>

<style>

body{
  margin:0;
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto;
  background:#f5f5f5;
  height:200vh;
}

/* 悬浮按钮 */
#ai-btn{
  position:fixed;
  right:24px;
  bottom:24px;
  width:64px;
  height:64px;
  border-radius:50%;
  background:#1677ff;
  color:#fff;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  box-shadow:0 4px 20px rgba(0,0,0,.2);
  z-index:99999;
  transition:.2s;
  font-size:28px;
}

#ai-btn:hover{
  transform:scale(1.06);
}

/* 聊天窗 */
#ai-window{
  position:fixed;
  right:24px;
  bottom:100px;
  width:360px;
  height:560px;
  background:#fff;
  border-radius:18px;
  overflow:hidden;
  box-shadow:0 10px 40px rgba(0,0,0,.15);
  display:none;
  flex-direction:column;
  z-index:99999;
}

/* 顶部 */
#ai-header{
  height:60px;
  background:#1677ff;
  color:#fff;
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:0 18px;
  font-size:16px;
}

#ai-close{
  cursor:pointer;
  font-size:24px;
}

/* 内容区 */
#ai-content{
  flex:1;
  overflow-y:auto;
  padding:16px;
  background:#f7f7f7;
}

/* 消息 */
.msg{
  margin-bottom:14px;
  display:flex;
}

.msg.user{
  justify-content:flex-end;
}

.msg.bot{
  justify-content:flex-start;
}

.msg span{
  max-width:78%;
  padding:10px 14px;
  border-radius:14px;
  line-height:1.5;
  word-break:break-word;
  font-size:14px;
}

.msg.user span{
  background:#1677ff;
  color:#fff;
}

.msg.bot span{
  background:#fff;
  color:#333;
  border:1px solid #eee;
}

/* 输入区 */
#ai-input-wrap{
  height:70px;
  border-top:1px solid #eee;
  display:flex;
  align-items:center;
  padding:0 12px;
  background:#fff;
}

#ai-input{
  flex:1;
  height:42px;
  border:1px solid #ddd;
  border-radius:22px;
  padding:0 14px;
  outline:none;
  font-size:14px;
}

#ai-send{
  margin-left:10px;
  width:72px;
  height:42px;
  border:none;
  border-radius:22px;
  background:#1677ff;
  color:#fff;
  cursor:pointer;
}

/* 手机 */
@media(max-width:768px){

  #ai-window{
    width:94%;
    height:82vh;
    right:3%;
    bottom:90px;
  }

  #ai-btn{
    right:18px;
    bottom:18px;
  }

}

</style>
</head>

<body>

<h1 style="padding:40px;">
  DeepSeek AI客服测试页面
</h1>

<!-- 悬浮球 -->
<div id="ai-btn">
  💬
</div>

<!-- 聊天窗 -->
<div id="ai-window">

  <div id="ai-header">
    <div>AI 智能助手</div>
    <div id="ai-close">×</div>
  </div>

  <div id="ai-content">

    <div class="msg bot">
      <span>
        你好 👋<br>
        我是 DeepSeek 智能助手
      </span>
    </div>

  </div>

  <div id="ai-input-wrap">
    <input id="ai-input" placeholder="请输入问题..." />
    <button id="ai-send">发送</button>
  </div>

</div>

<script>

// ======================
// DeepSeek配置
// ======================

const API_KEY = "sk-xxxxxxxxxxxxxxxx";

const API_URL = "https://api.deepseek.com/chat/completions";

const MODEL = "deepseek-chat";

// ======================
// DOM
// ======================

const btn = document.getElementById("ai-btn");
const win = document.getElementById("ai-window");
const closeBtn = document.getElementById("ai-close");

const input = document.getElementById("ai-input");
const sendBtn = document.getElementById("ai-send");

const content = document.getElementById("ai-content");

// ======================
// 上下文记忆
// ======================

const messages = [
  {
    role:"system",
    content:"你是一个专业的AI客服助手"
  }
];

// ======================
// 打开关闭
// ======================

btn.onclick = () => {

  const visible =
    getComputedStyle(win).display === "flex";

  win.style.display =
    visible ? "none" : "flex";

};

closeBtn.onclick = () => {
  win.style.display = "none";
};

// ======================
// 添加消息
// ======================

function addMessage(type,text){

  const div = document.createElement("div");

  div.className = `msg ${type}`;

  const span = document.createElement("span");

  span.textContent = text;

  div.appendChild(span);

  content.appendChild(div);

  content.scrollTop = content.scrollHeight;

  return div;

}

// ======================
// 发送消息
// ======================

async function sendMessage(){

  const question = input.value.trim();

  if(!question) return;

  // 用户消息
  addMessage("user",question);

  // 上下文
  messages.push({
    role:"user",
    content:question
  });

  input.value = "";

  // loading
  const loading = addMessage(
    "bot",
    "正在思考中..."
  );

  try{

    const response = await fetch(API_URL,{
      method:"POST",

      headers:{
        "Content-Type":"application/json",
        "Authorization":`Bearer ${API_KEY}`
      },

      body:JSON.stringify({
        model:MODEL,
        messages:messages,
        temperature:0.7
      })

    });

    if(!response.ok){

      throw new Error(
        "HTTP错误："+response.status
      );

    }

    const data = await response.json();

    console.log(data);

    const answer =
      data.choices?.[0]?.message?.content
      || "暂无回复";

    // 替换loading
    loading.querySelector("span").textContent =
      answer;

    // 保存上下文
    messages.push({
      role:"assistant",
      content:answer
    });

  }catch(err){

    console.error(err);

    loading.querySelector("span").textContent =
      "请求失败，请检查API Key或网络";

  }

  content.scrollTop = content.scrollHeight;

}

// ======================
// 发送按钮
// ======================

sendBtn.onclick = sendMessage;

// ======================
// 回车发送
// ======================

input.addEventListener("keydown",e=>{

  if(e.key==="Enter"){

    sendMessage();

  }

});

</script>

</body>
</html>
```
